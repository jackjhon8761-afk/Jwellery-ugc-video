# ============================================================================
# Jewellery UGC Video Studio — environment variables
#
# Copy this file to `backend/.env` (the server reads it from there) and fill
# in real values. NEVER commit the real .env file — it's already in .gitignore.
#
# See README.md for step-by-step instructions on obtaining each key.
# ============================================================================

# ---- Server -----------------------------------------------------------------
PORT=5000

# Public base URL the backend is reachable at. Creatify's API needs to be able
# to download the ornament photo you upload, so it must be a publicly
# reachable HTTPS URL — not "localhost". For local development, run a tunnel
# (e.g. `ngrok http 5000`) and paste the https URL it gives you here.
# TODO: verify this matches whatever domain/tunnel you are actually using.
PUBLIC_BASE_URL=http://localhost:5000

# ---- Creatify (Product-to-Video) --------------------------------------------
# Get these from your Creatify dashboard: https://app.creatify.ai/ -> Settings -> API
CREATIFY_API_ID=your-creatify-api-id
CREATIFY_API_KEY=your-creatify-api-key

# ---- OpenAI (caption generation) --------------------------------------------
# Get this from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ---- Instagram Graph API (publishing) ---------------------------------------
# Business/creator account ID (the IG user id behind your Facebook Page),
# obtained via the Graph API Explorer or Meta Business Suite.
IG_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id

# Long-lived Page access token with instagram_basic, instagram_content_publish,
# and pages_show_list permissions. See README.md for how to generate one.
IG_ACCESS_TOKEN=your-long-lived-instagram-access-token

# Graph API version to call. Check https://developers.facebook.com/docs/graph-api/changelog
# for the current version and bump this when Meta deprecates the old one.
# TODO: verify this is still a supported version when you deploy.
GRAPH_API_VERSION=v21.0
